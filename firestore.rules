rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilisateurs ──────────────────────────────────────────────────────────
    match /users/{userId} {
      // Lecture : tout utilisateur connecté (nécessaire pour le système d'amis)
      allow read: if request.auth != null;

      // Écriture : uniquement sur son propre document, avec validation
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.email == request.auth.token.email
                   && request.resource.data.username is string
                   && request.resource.data.username.size() >= 3
                   && request.resource.data.username.size() <= 30
                   && request.resource.data.listes is map;
    }

    // ── Pseudos (réservation atomique) ────────────────────────────────────────
    match /usernames/{username} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Un pseudo est définitif : ni modification ni suppression
      allow update, delete: if false;
    }

    // ── Demandes d'amis ───────────────────────────────────────────────────────
    match /friendRequests/{requestId} {
      // Lecture : tout utilisateur connecté
      // (Firestore ne supporte pas les conditions OR sur les requêtes de collection)
      allow read: if request.auth != null;

      // Création : je ne peux envoyer qu'en mon nom
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.status  == "pending"
                    && request.resource.data.fromUsername is string
                    && request.resource.data.toUsername   is string;

      // Mise à jour : le destinataire peut accepter, l'expéditeur peut annuler
      allow update: if request.auth != null && (
        resource.data.toUid   == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );

      // Suppression : l'une ou l'autre partie peut refuser / supprimer
      allow delete: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid   == request.auth.uid
      );
    }
  }
}
