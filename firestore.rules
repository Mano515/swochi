rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {

      // Lecture : tout utilisateur connecté peut lire les profils
      // (nécessaire pour la fonctionnalité Match — recherche par pseudo)
      allow read: if request.auth != null;

      // Écriture : uniquement sur son propre document
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   // Le champ email doit correspondre à l'email Firebase Auth
                   && request.resource.data.email == request.auth.token.email
                   // Le pseudo doit être présent, en minuscules, entre 3 et 30 caractères
                   && request.resource.data.username is string
                   && request.resource.data.username.size() >= 3
                   && request.resource.data.username.size() <= 30
                   // Les listes doivent être présentes
                   && request.resource.data.listes is map;
    }
  }
}
